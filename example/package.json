{
  "name": "OmicallChatExample",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "restart": "kill-port 8081 2>/dev/null; react-native start --reset-cache",
    "test": "jest",
    "postinstall": "node -e \"const fs=require('fs');['react-native','react'].forEach(p=>{const d=require('path').join('node_modules','omicall-chat-sdk','node_modules',p);try{fs.rmSync(d,{recursive:true,force:true});}catch{}});\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "omicall-chat-sdk": "file:..",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-device-info": "^10.0.0",
    "react-native-image-picker": "^8.2.1",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.76.5",
    "@react-native/eslint-config": "0.76.5",
    "@react-native/metro-config": "0.76.5",
    "@react-native/typescript-config": "0.76.5",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "escape-string-regexp": "^1.0.5",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "kill-port": "^2.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
